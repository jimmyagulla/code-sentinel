{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmit": true,
    "rootDir": "src"
  },
  "include": [
    "src/ui/webview/app/**/*",
    "src/constants/**/*",
    "src/application/dtos/NoteDto.ts",
    "src/application/dtos/ProjectConfigDto.ts",
    "src/application/dtos/notesPanelMessage.ts",
    "src/domain/value-objects/FileStatusValue.ts"
  ]
}
